# SIS (Student Information System) Configuration
# If integrating with an HTTP Microservice API:
SIS_API_URL=https://api.sis.university.edu/v1
SIS_API_KEY=

# If integrating directly with a Staging Relational Database:
SIS_DB_HOST=localhost
SIS_DB_PORT=5432
SIS_DB_NAME=sis_staging_db
SIS_DB_USER=postgres
SIS_DB_PASSWORD=

# LMS (Learning Management System) Configuration
LMS_API_URL=https://api.lms.university.edu/v1
LMS_API_KEY=

# CRM (Customer Relationship Management) Configuration
CRM_API_URL=https://api.crm.university.edu/v1
CRM_API_KEY=

# Gemini API Key (for the AI Assistant)
GEMINI_API_KEY=
